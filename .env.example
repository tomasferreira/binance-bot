# Binance API (get keys from Binance → API Management; use testnet keys for sandbox)
BINANCE_API_KEY=your_api_key_here
BINANCE_API_SECRET=your_api_secret_here

# Use testnet (default is true; set to 'false' ONLY for live trading)
TESTNET=true

# Trading pair and timeframe
SYMBOL=BTC/USDT
TIMEFRAME=15m

# Regime (volatility + trend): separate timeframe and bars for dashboard only
REGIME_TIMEFRAME=1h
REGIME_CANDLES=200
# Only allow entries when regime fits strategy (set to false to disable; can also toggle in dashboard)
REGIME_FILTER_ENABLED=true

# Poll interval in milliseconds (how often the bot fetches candles and evaluates strategies)
POLL_INTERVAL_MS=60000

# Risk and R:R settings
RISK_PER_TRADE=0.01
STOP_LOSS_PCT=0.02
TAKE_PROFIT_PCT=0.04
GLOBAL_BUDGET_USDT=0

# Testing mode (if true, no real orders are placed)
TESTING_MODE=false

# Fee rate per side (decimal; e.g. 0.001 = 0.1%). Used for position sizing.
FEE_RATE_PCT=0.001

# HTTP API and dashboard port
API_PORT=3000

# Comma-separated assets to log in balance summary
ASSETS_TO_LOG=BTC,USDT

# Logging
LOG_LEVEL=INFO
LOG_MAX_SIZE_MB=10
LOG_MAX_FILES=5

# Max closed trades kept per strategy (analysis + chart); 100–10000
CLOSED_TRADES_HISTORY_LIMIT=500
