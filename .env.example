# Binance API (get keys from Binance → API Management; use testnet keys for sandbox)
BINANCE_API_KEY=your_api_key_here
BINANCE_API_SECRET=your_api_secret_here

# Use testnet (set to 'false' for live trading)
TESTNET=true

# All other settings (symbol, timeframe, risk, regime, logging, etc.) are in config.json.
# Optional: set any of these env vars to override config.json (e.g. SYMBOL=ETH/USDT).
